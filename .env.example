# ============================================
# Ari - Assistant Vocal IA Local
# Fichier d'exemple de variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs
# ============================================

# === Serveur API ===
# Hôte d'écoute du serveur (0.0.0.0 pour tous les interfaces)
HOST=0.0.0.0
# Port d'écoute (par défaut: 8000)
PORT=8080
# workers uvicorn (1 pour dev, plus pour prod)
WORKERS=1

# === Sécurité ===
# Clé secrète pour sessions/jwt (générer avec: openssl rand -hex 32)
SECRET_KEY=change_this_secret_key_with_secure_random_value
# Hash bcrypt du code PIN administrateur (générer avec: python -c "import bcrypt; print(bcrypt.hashpw(b'PIN1234', bcrypt.gensalt()).decode())")
ADMIN_PIN_HASH=$2b$12$E2Wvi7RzNn8VZN1Y5YFZAe5Z5Za5Za5Za5Za5Za5Za5Za5Za5Za5
# Durée de vie des tokens JWT en minutes (défaut: 60)
TOKEN_EXPIRE_MINUTES=60

# === Configuration TTS (Text-to-Speech) ===
# Moteur TTS: 'edge' (Edge-TTS) ou 'piper' (piper-tts) ou 'coqui' (coqui-tts)
TTS_ENGINE=edge
# Voix Edge-TTS (ex: fr-FR-DeniseNeural, fr-FR-HenriNeural, en-US-JennyNeural)
EDGE_TTS_VOICE=fr-FR-DeniseNeural
# Taux de parole (0.5 à 2.0, 1.0 = normal)
TTS_RATE=1.0
# Pitch (fréquence) -50 à 50
TTS_PITCH=0
# Volume 0.0 à 1.0
TTS_VOLUME=1.0

# === Configuration Whisper (STT) ===
# Modèle Whisper: tiny, base, small, medium, large
WHISPER_MODEL=base
# Langue principale pour transcription (ex: fr, en, es)
WHISPER_LANGUAGE=fr
# Dossier de stockage des modèles Whisper (optionnel)
WHISPER_MODELS_DIR=./whisper_models

# === Configuration LLM (Ollama) ===
# URL du serveur Ollama local
OLLAMA_BASE_URL=http://localhost:11434
# Modèle Ollama à utiliser (ex: llama3.2, mistral, codellama)
OLLAMA_MODEL=llama3.2
# Paramètres de génération
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=2048
# Timeout des requêtes Ollama en secondes
OLLAMA_TIMEOUT=120

# === Mémoire & Profiles ===
# Chemin des profils utilisateurs (mémoire à long terme)
MEMORY_PROFILES_DIR=./memory_profiles
# Fichier de mémoire contextuelle temporaire (conversation en cours)
MEMORY_CONTEXT_FILE=./memory_context.json
# Taille max historique conversation (derniers N échanges)
MAX_CONVERSATION_HISTORY=20

# === Recherche & Connaissances ===
# Clé API Tavily (optionnelle - recherche web)
TAVILY_API_KEY=
# Activation recherche web automatique si True
ENABLE_WEB_SEARCH=False
# Domaine restreint pour la recherche (ex: *.wikipedia.org)
SEARCH_ALLOWED_DOMAINS=*.wikipedia.org,*.fr
# Nombre max de résultats de recherche
MAX_SEARCH_RESULTS=5

# === Base de données ===
# Chemin fichier SQLite (optionnel, pour logs/audit)
DATABASE_PATH=./data/ari.db
# Créer automatically les tables si True
DB_AUTO_MIGRATE=True

# === Logging ===
# Niveau de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Fichier de log principal
LOG_FILE=./logs/ari.log
# Rotation des logs: taille max en bytes (ex: 10485760 = 10MB)
LOG_MAX_BYTES=10485760
# Nombre de fichiers de rotation à conserver
LOG_BACKUP_COUNT=5

# === Audio & Micro ===
# Périphérique d'entrée audio (index ou nom)
AUDIO_INPUT_DEVICE=
# Périphérique de sortie audio (index ou nom)
AUDIO_OUTPUT_DEVICE=
# Seuil de détection vocal (VAD) - 0.0 à 1.0
VAD_THRESHOLD=0.5
# Durée min d'enregistrement après silence (secondes)
VAD_SILENCE_DURATION=0.8

# === Wake Word (mot d'activation) ===
# Mot d'activation (ex: "Ari", "Assistant")
WAKE_WORD=Ari
# Chemin modèle wake word (si utilisé)
WAKE_WORD_MODEL_PATH=./models/wakeword.pmdl
# Seuil de confiance wake word (0.0 à 1.0)
WAKE_WORD_THRESHOLD=0.7

# === CORS & Réseau ===
# Origines autorisées pour CORS (séparé par virgules)
CORS_ALLOW_ORIGINS=*
# Activer HTTPS (redirection) si True
ENABLE_HTTPS_REDIRECT=False

# === Mode Débogage ===
# Mode debug (affichage détaillé, reload auto)
DEBUG=False
# Désactiver les vérifications de sécurité en dev
DISABLE_SECURITY=False

# === Fonctionnalités optionnelles ===
# Activer le système de commandes vocales personnalisées
ENABLE_CUSTOM_COMMANDS=False
# Activer l'apprentissage automatique des préférences
ENABLE_LEARNING=True
# Activer le synthèse vocale émotionnelle (si supporté)
ENABLE_EMOTION_TTS=False
