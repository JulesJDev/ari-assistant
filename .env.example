# ============================================
# Ari Assistant — Environment Configuration
# ============================================
# Copy this file to .env and adjust values as needed.
# ============================================

# --- LLM Provider (OpenRouter) ---
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.2-3b-instruct:free,mistralai/mistral-7b-instruct:free
OPENROUTER_MAX_MODEL_TRIES=6

# --- TTS (Text-to-Speech) ---
# Edge TTS voice (Microsoft Azure neural voices)
EDGE_VOICE=fr-FR-DeniseNeural
# Rate: percentage modifier (e.g. +25%, -10%, +0%)
EDGE_RATE=+25%
# Pitch: Hz modifier (e.g. +0Hz, +10Hz, -5Hz)
EDGE_PITCH=+0Hz
# Volume: percentage modifier (e.g. +0%, +20%, -10%)
EDGE_VOLUME=+0%
# Timeout for Edge TTS requests (seconds)
EDGE_TTS_TIMEOUT=18

# --- Piper TTS (optional local fallback) ---
# Path to piper executable (leave empty to disable)
PIPER_BIN=
# Path to piper model file (leave empty if not used)
PIPER_MODEL_PATH=

# --- Memory & Context ---
# Maximum raw memory turns to store (1 turn = 1 user + 1 assistant msg)
MEMORY_MAX_TURNS=80
# Number of recent turns injected into prompt
MEMORY_PROMPT_TURNS=6
# Memory compression optimizer interval in seconds (4h)
MEMORY_OPTIMIZE_INTERVAL_SEC=14400

# --- Default User/Profile ---
DEFAULT_USER_ID=default
DEFAULT_PROFILE_ID=default

# --- General ---
AI_NAME=Ari
# Enable/disable internet search by default
INTERNET_ENABLED_DEFAULT=true

# --- Web Search ---
# Provider: auto, tavily, ddgs, duckduckgo
WEB_SEARCH_PROVIDER=auto
# Tavily API key (optional, required for tavily provider)
TAVILY_API_KEY=

# --- LLM Settings ---
# Maximum reasoning block size (chars) before truncation
REASONING_BAIL_MAX_CHARS=8192

# --- Server ---
# Port to run uvicorn on (use 8000 local, 8080 on local network)
PORT=8000
